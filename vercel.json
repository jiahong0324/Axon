{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets/|api/|icons/|manifest\\.json|favicon\\.ico|.*\\..*$).*)", "destination": "/index.html" }
  ]
}
